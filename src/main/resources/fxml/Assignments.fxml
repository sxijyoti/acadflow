<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.acadflow.ui.controllers.AssignmentsController" fx:id="assignmentsContainer" spacing="20" style="-fx-padding: 20;">
    
    <Label text="Assignments" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <HBox spacing="15">
        <Label text="Filter by Status:"/>
        <ComboBox fx:id="statusFilter" style="-fx-min-width: 120;"/>
    </HBox>

    <TableView fx:id="assignmentsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Assignment Title" prefWidth="150"/>
            <TableColumn fx:id="subjectColumn" text="Subject" prefWidth="100"/>
            <TableColumn fx:id="deadlineColumn" text="Deadline" prefWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
            <TableColumn fx:id="actionColumn" text="Actions" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>
