<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.acadflow.ui.controllers.MainWindowController" fx:id="mainBorderPane">
    <!-- Top Bar -->
    <top>
        <HBox spacing="20" style="-fx-padding: 15; -fx-background-color: #2c3e50; -fx-alignment: CENTER_RIGHT;">
            <HBox spacing="10" HBox.hgrow="ALWAYS">
                <Label text="🎓 Academic Workflow Management System" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
            </HBox>
            <VBox spacing="2" style="-fx-text-fill: white;">
                <Label fx:id="userNameLabel" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label fx:id="userRoleLabel" style="-fx-text-fill: #ecf0f1; -fx-font-size: 11;"/>
            </VBox>
            <Button text="Logout" style="-fx-padding: 8 15; -fx-font-size: 12;"/>
        </HBox>
    </top>

    <!-- Content Area -->
    <center>
        <HBox spacing="0">
            <!-- Sidebar -->
            <VBox fx:id="sidebar" spacing="10" style="-fx-padding: 20; -fx-background-color: #34495e; -fx-min-width: 220; -fx-border-color: #2c3e50;" VBox.vgrow="ALWAYS">
                <Label text="NAVIGATION" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12;"/>
                <Separator/>
                
                <Button fx:id="dashboardBtn" text="📊 Dashboard" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="calendarBtn" text="📅 Calendar" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="subjectsBtn" text="📚 Subjects" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="assignmentsBtn" text="📝 Assignments" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="resourcesBtn" text="📖 Resources" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="timetableBtn" text="⏰ Timetable" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="examsBtn" text="🧪 Exams" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="profileBtn" text="👤 Profile" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                <Button fx:id="holidaysBtn" text="🎉 Holidays" style="-fx-padding: 10 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
                
                <Separator VBox.vgrow="ALWAYS"/>
                
                <Button fx:id="logoutBtn" text="🚪 Logout" style="-fx-padding: 10 15; -fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
            </VBox>

            <!-- Main Content Area -->
            <VBox fx:id="contentArea" spacing="0" HBox.hgrow="ALWAYS" style="-fx-padding: 20; -fx-background-color: #ecf0f1;"/>
        </HBox>
    </center>
</BorderPane>
