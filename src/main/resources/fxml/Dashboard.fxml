<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.acadflow.ui.controllers.DashboardController" fx:id="dashboardContainer" spacing="20" style="-fx-padding: 20;">
    
    <Label fx:id="welcomeLabel" text="Dashboard" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <!-- Overview Cards -->
    <VBox fx:id="overviewCardsContainer" spacing="10"/>
    
    <!-- Upcoming Events Section -->
    <TitledPane text="Upcoming Deadlines" collapsible="false" style="-fx-padding: 10;">
        <VBox fx:id="upcomingContainer" spacing="10" style="-fx-padding: 10;"/>
    </TitledPane>
    
    <!-- Quick Links Section -->
    <TitledPane text="Quick Links" collapsible="false" style="-fx-padding: 10;">
        <VBox fx:id="quickLinksContainer" spacing="10" style="-fx-padding: 10;"/>
    </TitledPane>
    
    <Region VBox.vgrow="ALWAYS"/>
</VBox>
