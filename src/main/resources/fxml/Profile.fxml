<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.acadflow.ui.controllers.ProfileController" fx:id="profileContainer" spacing="20" style="-fx-padding: 30;">
    
    <Label text="👤 User Profile" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
    
    <Separator/>
    
    <GridPane hgap="20" vgap="15" style="-fx-padding: 20;">
        <columnConstraints>
            <ColumnConstraints percentWidth="30"/>
            <ColumnConstraints percentWidth="70"/>
        </columnConstraints>

        <!-- Name -->
        <Label text="Name:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <!-- Email -->
        <Label text="Email:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="emailField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <!-- Phone -->
        <Label text="Phone:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <!-- Department -->
        <Label text="Department:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="departmentField" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <!-- Semester -->
        <Label text="Semester:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="semesterField" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <!-- Role -->
        <Label text="Role:" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <Label fx:id="roleLabel" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
    </GridPane>

    <Separator/>
    
    <!-- Buttons -->
    <HBox spacing="10">
        <Button fx:id="editButton" text="✏️ Edit" style="-fx-padding: 10 20; -fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button fx:id="saveButton" text="💾 Save" style="-fx-padding: 10 20; -fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button fx:id="cancelButton" text="❌ Cancel" style="-fx-padding: 10 20; -fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>
    
    <Region VBox.vgrow="ALWAYS"/>
</VBox>
